PORT=5000

# Cloudflare D1 (SQL database on Cloudflare's edge)
# Get these from: https://dash.cloudflare.com -> Workers & Pages -> D1
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_D1_DATABASE_ID=your_d1_database_id
CF_API_TOKEN=your_cloudflare_api_token

# JWT
JWT_SECRET=nutrisync_jwt_secret_change_in_production

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
NODE_ENV=development
